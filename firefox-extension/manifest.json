{
  "manifest_version": 3,
  "name": "DSS Companion",
  "version": "1.0",
  "description": "Save and search with DeepSearchStack — right-click to search, save pages to your warehouse.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:8014/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "DSS Search",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+D"
      }
    }
  }
}
