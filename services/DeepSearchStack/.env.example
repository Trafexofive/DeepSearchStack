# DeepSearchStack — Environment Template
# Copy to .env and fill in your values
# LLM routing via substrate inference-gateway (port 8005)

# --- DeepSeek (primary compute, via inference-gateway) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- Database ---
POSTGRES_DB=searchdb
POSTGRES_USER=searchuser
POSTGRES_PASSWORD=searchpass

# --- Search Providers (optional API keys) ---
# Most search backends (SearXNG, Whoogle, YaCy) are self-hosted, no keys needed.
