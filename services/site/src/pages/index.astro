---
import Base from "../layouts/Base.astro";
import { SITE } from "../site.config";

const allPosts = Object.entries(import.meta.glob("/src/content/posts/*.mdx", { eager: true }))
  .map(([path, mod]: [string, any]) => {
    const slug = path.split("/").pop()?.replace(".mdx", "") || "";
    return { slug, ...mod.frontmatter };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const latest = allPosts.slice(0, 8);

const categories = [
  { slug: "news",      label: "📡 News",       count: allPosts.filter(p => p.category === "news").length,      desc: "What actually matters" },
  { slug: "guides",    label: "📖 Guides",      count: allPosts.filter(p => p.category === "guide").length,     desc: "Walkthroughs & tutorials" },
  { slug: "benchmarks",label: "⚡ Benchmarks",   count: allPosts.filter(p => p.category === "benchmark").length, desc: "Hard data, no fluff" },
  { slug: "research",  label: "🔬 Research",     count: allPosts.filter(p => p.category === "research").length,  desc: "Papers, explained" },
  { slug: "opinion",   label: "🗣 Opinion",     count: allPosts.filter(p => p.category === "opinion").length,    desc: "Based takes" },
];
---

<Base>
  <!-- Terminal intro -->
  <div class="terminal-block">
    <pre><code><span class="prompt-prefix">$ ssh</span> <span class="prompt">{SITE.title.toLowerCase()}.pub</span>
<span class="prompt-prefix">&gt;</span> {SITE.tagline}
<span class="prompt-prefix">&gt;</span> {allPosts.length} posts · {categories.reduce((s, c) => s + c.count, 0)} across {categories.length} categories
<span class="prompt-prefix">$</span> <span class="cursor">█</span></code></pre>
  </div>

  <!-- Category grid -->
  <div class="category-grid">
    {categories.map(c => (
      <a href={`/${c.slug}`} class="category-card">
        <span class="card-icon">{c.label.split(" ")[0]}</span>
        <span class="card-label">{c.label.split(" ").slice(1).join(" ")}</span>
        <span class="card-count">{c.count} posts</span>
        <span class="card-desc">{c.desc}</span>
      </a>
    ))}
    <a href="/generate" class="category-card accent">
      <span class="card-icon">🤖</span>
      <span class="card-label">Generate</span>
      <span class="card-count">live</span>
      <span class="card-desc">AI-powered, researched</span>
    </a>
  </div>

  <!-- Latest posts -->
  <h2 class="section-heading">Latest</h2>
  <div class="post-feed">
    {latest.map(post => (
      <article class="post-item">
        <time class="post-date" datetime={new Date(post.date).toISOString()}>{new Date(post.date).toISOString().slice(0, 10)}</time>
        <a href={`/posts/${post.slug}`} class="post-link">{post.title}</a>
        <span class="chip chip-category">{post.category}</span>
        {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
        {(post.tags as string[])?.map(t => <span class="chip chip-tag">{t}</span>)}
      </article>
    ))}
  </div>

  {allPosts.length > 8 && <p style="margin-top:var(--space-5);font-size:var(--text-xs)"><a href="/archive">→ all {allPosts.length} posts</a></p>}
</Base>
