---
import Base from "../layouts/Base.astro";
---

<Base title="Admin">
  <h1>Admin</h1>
  <p style="color:var(--border);font-size:var(--text-sm);margin-top:-1rem;margin-bottom:var(--space-6)">Blog generator runtime — stats, history, pipeline health.</p>

  <h2 class="section-heading">Pipeline</h2>
  <div class="pipeline-indicator" id="pipeline">
    <span class="pipeline-chip">checking…</span>
  </div>

  <h2 class="section-heading">Stats</h2>
  <div class="stat-grid" id="stats-grid">
    <div class="stat-card"><span class="stat-value">—</span><span class="stat-label">loading</span></div>
  </div>

  <h2 class="section-heading">Recent Generations</h2>
  <div id="history"><p style="color:var(--border);font-size:var(--text-sm)">Loading…</p></div>
</Base>

<script>
  async function load() {
    // Pipeline health
    const pipeline = document.getElementById("pipeline")!;
    const services = [
      { label: "blog-gen",  url: "/api/health" },
      { label: "inference", url: "/api/health" },  // blog-gen proxies health checks
    ];
    pipeline.innerHTML = "";
    for (const srv of services) {
      try {
        const r = await fetch(srv.url);
        const cls = r.ok ? "up" : "down";
        pipeline.innerHTML += `<span class="pipeline-chip ${cls}">${srv.label} ${r.ok ? "✓" : r.status}</span>`;
      } catch {
        pipeline.innerHTML += `<span class="pipeline-chip down">${srv.label} ✗</span>`;
      }
    }

    // Stats
    try {
      const s = await fetch("/api/stats").then(r => r.json());
      document.getElementById("stats-grid")!.innerHTML = `
        <div class="stat-card"><span class="stat-value">${s.total_generations}</span><span class="stat-label">generations</span></div>
        <div class="stat-card"><span class="stat-value">${s.total_tokens.toLocaleString()}</span><span class="stat-label">tokens</span></div>
        <div class="stat-card"><span class="stat-value">\$${s.total_cost_usd.toFixed(4)}</span><span class="stat-label">cost</span></div>
        <div class="stat-card"><span class="stat-value">${Math.round(s.avg_duration_ms)}ms</span><span class="stat-label">avg duration</span></div>
      `;
    } catch {
      document.getElementById("stats-grid")!.innerHTML = `<p style="color:var(--border)">blog_generator unreachable</p>`;
    }

    // History
    try {
      const h = await fetch("/api/history?limit=20").then(r => r.json());
      if (!Array.isArray(h) || h.length === 0) {
        document.getElementById("history")!.innerHTML = `<div class="empty-state"><p>No generations yet.</p><p style="margin-top:var(--space-3)"><a href="/generate">→ run the first one</a></p></div>`;
        return;
      }
      document.getElementById("history")!.innerHTML = h.map((g: any) => `
        <article class="post-item">
          <time class="post-date">${(g.created_at ?? "").slice(0, 10)}</time>
          <div class="post-link" style="font-size:var(--text-base)">${g.topic}</div>
          <span style="font-size:var(--text-xs);color:var(--border)">${g.model} · ${g.total_tokens ?? 0} tokens · \$${g.cost_usd ?? "?"} · ${g.duration_ms ?? 0}ms · <span style="color:${g.status === "ok" ? "var(--signal-dim)" : "#ff6666"}">${g.status}</span></span>
        </article>
      `).join("");
    } catch {
      document.getElementById("history")!.innerHTML = `<p style="color:#ff6666;font-size:var(--text-sm)">Could not load history</p>`;
    }
  }

  load();
</script>
