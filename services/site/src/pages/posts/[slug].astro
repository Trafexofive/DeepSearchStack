---
import Base from "../../layouts/Base.astro";
import { SITE, AUTHOR } from "../../site.config";

export async function getStaticPaths() {
  const modules = import.meta.glob("/src/content/posts/*.mdx", { eager: true });
  return Object.entries(modules).map(([path, mod]: [string, any]) => {
    const slug = path.split("/").pop()?.replace(".mdx", "") || "";
    return {
      params: { slug },
      props: { slug, frontmatter: mod.frontmatter, Content: mod.default },
    };
  });
}

const { slug, frontmatter, Content } = Astro.props;
const date = new Date(frontmatter.date);
const dateISO = date.toISOString();
const authorName = frontmatter.author ?? AUTHOR.name;

// Build HowTo schema if this is a guide with steps in frontmatter
const howto = frontmatter.howto ?? undefined;

// Build FAQ from frontmatter if present
const faq = frontmatter.faq ?? undefined;
---

<Base
  title={frontmatter.title}
  description={frontmatter.excerpt ?? AUTHOR.description}
  type="article"
  canonicalURL={`${SITE.url}/posts/${slug}/`}
  publishedTime={dateISO}
  modifiedTime={frontmatter.modified ? new Date(frontmatter.modified).toISOString() : dateISO}
  authorName={authorName}
  authorUrl={AUTHOR.url}
  tags={[frontmatter.category, ...(frontmatter.tags || [])]}
  faq={faq}
  howto={howto}
>
  <article>
    <header class="article-header">
      <div class="article-meta">
        <a href={`/${frontmatter.category === "guide" ? "guides" : frontmatter.category + "s"}`} class="chip chip-category">{frontmatter.category}</a>
        <time datetime={dateISO}>{dateISO.slice(0, 10)}</time>
        {` · by ${authorName}`}
        {frontmatter.modified && frontmatter.modified !== frontmatter.date && ` · updated ${new Date(frontmatter.modified).toISOString().slice(0, 10)}`}
      </div>

      <h1 class="article-title">{frontmatter.title}</h1>

      {frontmatter.excerpt && <p style="color:var(--border);max-width:var(--measure-narrow);font-size:var(--text-sm);line-height:var(--leading);margin-bottom:var(--space-4)">{frontmatter.excerpt}</p>}

      {(frontmatter.tags || []).length > 0 && (
        <div>{(frontmatter.tags as string[]).map((t: string) => <span class="chip chip-tag">{t}</span>)}</div>
      )}
    </header>

    <div class="article-body">
      <Content />
    </div>

    <!-- FAQ section -->
    {faq && faq.length > 0 && (
      <section style="margin-top:var(--space-7);padding-top:var(--space-5);border-top:1px solid var(--border)">
        <h2 id="faq">Frequently Asked Questions</h2>
        {faq.map((q, i) => (
          <details style="margin-bottom:var(--space-3)">
            <summary style="font-weight:600;cursor:pointer;margin-bottom:var(--space-2)">{q.question}</summary>
            <p style="color:var(--text-secondary);margin-left:var(--space-5)">{q.answer}</p>
          </details>
        ))}
      </section>
    )}
  </article>

  <hr />
  <p style="font-size:var(--text-xs)"><a href="/">← home</a> · <a href="/archive">archive</a> · <a href="/rss.xml">rss</a></p>
</Base>
