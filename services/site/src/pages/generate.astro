---
import Base from "../layouts/Base.astro";
---

<Base title="Generate">
  <h1>Generate</h1>
  <p class="muted">AI-powered blog generation via Substrate inference pipeline. Research-backed, with real sources and citations.</p>
  <hr />

  <div class="generate-form">
    <label for="topic">Topic</label>
    <input type="text" id="topic" placeholder="e.g. Zero-dependency async runtime design in Rust" />

    <label for="style">Style</label>
    <select id="style">
      <option value="technical">Technical — precise, code examples, senior eng</option>
      <option value="tutorial">Tutorial — step-by-step, prerequisites, working code</option>
      <option value="thought">Thought — exploratory, opinionated, trade-offs</option>
    </select>

    <label for="mode">Mode</label>
    <select id="mode">
      <option value="researched">Researched — DeepSearch → sources → generate</option>
      <option value="simple">Simple — direct LLM generation (no research)</option>
    </select>

    <details style="margin-top:1rem">
      <summary style="cursor:pointer;font-size:0.75rem;color:var(--fg-muted);text-transform:uppercase">Advanced options</summary>
      <label for="model">Model</label>
      <select id="model">
        <option value="deepseek-v4-flash">deepseek-v4-flash</option>
        <option value="deepseek-chat">deepseek-chat</option>
        <option value="deepseek-reasoner">deepseek-reasoner</option>
      </select>
      <label for="max_tokens">Max tokens</label>
      <input type="number" id="max_tokens" value="2048" min="256" max="8192" />
      <label for="temperature">Temperature</label>
      <input type="number" id="temperature" value="0.7" min="0" max="2" step="0.1" />
    </details>

    <button id="generate-btn" onclick="generate()">▶ Generate</button>
  </div>

  <div id="status" style="display:none" class="muted" style="margin:1rem 0;font-size:0.8rem"></div>
  <div id="result" style="display:none"></div>
</Base>

<script>
  const API = "http://localhost:8006";
  // In production: relative URL or env-configured endpoint

  async function generate() {
    const btn = document.getElementById("generate-btn") as HTMLButtonElement;
    const status = document.getElementById("status")!;
    const result = document.getElementById("result")!;

    const topic = (document.getElementById("topic") as HTMLInputElement).value.trim();
    if (!topic) { alert("Enter a topic"); return; }

    const mode = (document.getElementById("mode") as HTMLSelectElement).value;
    const endpoint = mode === "researched" ? "/generate-researched" : "/generate";
    const style = (document.getElementById("style") as HTMLSelectElement).value;
    const model = (document.getElementById("model") as HTMLSelectElement)?.value || "deepseek-v4-flash";
    const maxTokens = parseInt((document.getElementById("max_tokens") as HTMLInputElement)?.value || "2048");
    const temperature = parseFloat((document.getElementById("temperature") as HTMLInputElement)?.value || "0.7");

    btn.disabled = true;
    btn.textContent = "⏳ Generating...";
    status.style.display = "block";
    status.textContent = mode === "researched" ? "Researching topic..." : "Generating...";
    result.style.display = "none";
    result.innerHTML = "";

    try {
      const start = Date.now();
      const resp = await fetch(`${API}${endpoint}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ topic, style, model, max_tokens: maxTokens, temperature }),
      });
      const data = await resp.json();
      const elapsed = ((Date.now() - start) / 1000).toFixed(1);

      if (resp.ok) {
        result.innerHTML = `
          <div class="result-block">
            <div class="muted" style="margin-bottom:0.5rem">
              ${data.model} · ${data.usage.total_tokens} tokens · \$${data.cost_usd} · ${elapsed}s
              ${data.sources?.length ? `· ${data.sources.length} sources` : ""}
            </div>
            ${data.sources?.length ? `<div class="muted" style="margin-bottom:1rem;font-size:0.75rem">Sources: ${data.sources.map((s: any) => s.title).join(", ")}</div>` : ""}
            <hr style="margin:0.5rem 0" />
            ${data.content.replace(/\n/g, "<br>")}
          </div>`;
        result.style.display = "block";
        status.textContent = `✅ Done — ${elapsed}s`;
      } else {
        result.innerHTML = `<div class="error-block">${data.detail || "Generation failed"}</div>`;
        result.style.display = "block";
        status.textContent = "❌ Failed";
      }
    } catch (e: any) {
      result.innerHTML = `<div class="error-block">${e.message || "Network error — is blog_generator running on :8006?"}</div>`;
      result.style.display = "block";
      status.textContent = "❌ Connection error";
    } finally {
      btn.disabled = false;
      btn.textContent = "▶ Generate";
    }
  }
</script>
