---
import Base from "../layouts/Base.astro";
---

<Base title="Generate">
  <h1>Generate</h1>
  <p style="color:var(--border);font-size:var(--text-sm);margin-top:-1rem;margin-bottom:var(--space-6)">AI-powered blog generation. DeepSearch → DeepSeek → cited synthesis. Review before publish.</p>

  <form id="gen-form" class="panel" autocomplete="off">
    <div class="form-group">
      <label class="form-label" for="topic">Topic</label>
      <input type="text" id="topic" name="topic" placeholder="e.g. Designing a zero-dependency async runtime in Rust" required minlength="10" />
    </div>

    <div class="form-row">
      <div class="form-col">
        <label class="form-label" for="style">Style</label>
        <select id="style">
          <option value="technical">Technical — precise, code examples</option>
          <option value="tutorial">Tutorial — step-by-step</option>
          <option value="thought">Thought — opinionated, tradeoffs</option>
        </select>
      </div>
      <div class="form-col">
        <label class="form-label" for="mode">Mode</label>
        <select id="mode">
          <option value="researched">Researched — sources + generation</option>
          <option value="simple">Simple — direct LLM generation</option>
        </select>
      </div>
    </div>

    <button type="button" class="advanced-toggle" id="advanced-toggle">Advanced</button>
    <div class="advanced-panel" id="advanced-panel">
      <div class="form-row">
        <div class="form-col">
          <label class="form-label" for="model">Model</label>
          <select id="model">
            <option value="deepseek-v4-flash">deepseek-v4-flash</option>
            <option value="deepseek-chat">deepseek-chat</option>
            <option value="deepseek-reasoner">deepseek-reasoner</option>
          </select>
        </div>
        <div class="form-col">
          <label class="form-label" for="max_tokens">Max tokens</label>
          <input type="number" id="max_tokens" value="2048" min="256" max="8192" />
        </div>
        <div class="form-col">
          <label class="form-label" for="temperature">Temperature</label>
          <input type="number" id="temperature" value="0.7" min="0" max="2" step="0.1" />
        </div>
      </div>
    </div>

    <button type="submit" class="btn btn-primary" id="gen-btn" style="margin-top:var(--space-5)">▶ Generate</button>
  </form>

  <div id="status" class="status-bar"></div>

  <div id="result" class="result-block">
    <div class="result-meta" id="result-meta"></div>
    <div class="result-sources" id="result-sources" style="display:none"></div>
    <div class="result-content" id="result-content"></div>
  </div>

  <div id="error" class="error-block" style="display:none"></div>
</Base>

<script>
  const els = (id: string) => document.getElementById(id)!;

  els("advanced-toggle").addEventListener("click", () => {
    const panel = els("advanced-panel");
    const btn = els("advanced-toggle");
    panel.classList.toggle("visible");
    btn.classList.toggle("open");
  });

  const form = els("gen-form") as HTMLFormElement;
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const topic       = (els("topic") as HTMLInputElement).value.trim();
    const style       = (els("style") as HTMLSelectElement).value;
    const mode        = (els("mode") as HTMLSelectElement).value;
    const model       = (els("model") as HTMLSelectElement).value;
    const maxTokens   = parseInt((els("max_tokens") as HTMLInputElement).value || "2048");
    const temperature = parseFloat((els("temperature") as HTMLInputElement).value || "0.7");

    const endpoint = mode === "researched" ? "/api/generate-researched" : "/api/generate";
    const btn = els("gen-btn") as HTMLButtonElement;

    // Show working state
    btn.disabled = true;
    btn.textContent = "⏳ Working…";
    const status = els("status");
    status.className = "status-bar visible info";
    status.textContent = mode === "researched" ? "Researching → synthesizing…" : "Generating…";

    els("result").classList.remove("visible");
    els("error").style.display = "none";

    try {
      const t0 = performance.now();
      const resp = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ topic, style, model, max_tokens: maxTokens, temperature }),
      });

      const data = await resp.json();
      const elapsed = ((performance.now() - t0) / 1000).toFixed(1);

      if (!resp.ok) {
        throw new Error(data.detail ?? `HTTP ${resp.status}`);
      }

      // Status
      const srcCount = data.sources?.length ?? 0;
      status.className = "status-bar visible ok";
      status.textContent = `✅ ${data.model} · ${data.usage?.total_tokens} tokens · \$${data.cost_usd} · ${elapsed}s${srcCount ? ` · ${srcCount} sources` : ""}`;

      // Meta
      els("result-meta").textContent = `${style} · ${data.model} · ${data.usage?.total_tokens ?? "?"} tokens · \$${data.cost_usd ?? "?"}`;

      // Sources
      if (srcCount) {
        const srcDiv = els("result-sources");
        srcDiv.style.display = "block";
        srcDiv.innerHTML = `<h4>Sources</h4><ol>${data.sources.map((s: any) => `<li><a href="${s.url ?? "#"}" rel="nofollow">${s.title}</a></li>`).join("")}</ol>`;
      } else {
        els("result-sources").style.display = "none";
      }

      // Content
      els("result-content").innerHTML = data.content;
      els("result").classList.add("visible");

      // Scroll to result
      els("result").scrollIntoView({ behavior: "smooth", block: "start" });

    } catch (err: any) {
      status.className = "status-bar visible error";
      status.textContent = "✕ Generation failed";
      els("error").textContent = err.message;
      els("error").style.display = "block";
    } finally {
      btn.disabled = false;
      btn.textContent = "▶ Generate";
    }
  });
</script>
