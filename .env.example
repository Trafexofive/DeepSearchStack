# ─── Substrate Environment ───────────────────────────────────────────────────
# Copy to .env and fill in your values.

# LLM Gateway
LLM_PROVIDER=ollama          # ollama | groq | openai
LLM_MODEL=llama3.2:latest
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=        # NVIDIA NIM free tier — 40 RPM, 40+ models (GLM, MiniMax, Llama, Qwen, etc.)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Relics / Persistence
POSTGRES_URL=postgresql://substrate:substrate@ledger_db:5432/substrate
NEO4J_URI=bolt://recon_graph:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=substrate
REDIS_URL=redis://event_bus:6379/0

# API Gateway
API_GATEWAY_PORT=8000
JWT_SECRET=change-me-to-a-random-secret

# Event Bus
EVENT_BUS_REDIS_URL=redis://event_bus:6379/0

# Workflow Engine
WORKFLOW_MAX_RETRIES=3
WORKFLOW_RETRY_DELAY_SECS=5

# Webhooks
STRIPE_WEBHOOK_SECRET=
